# Navigator - Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Cloud API Keys ──────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key
GROQ_API_KEY=your_groq_api_key

# ── Audio ───────────────────────────────────────────────────────────────────
MIC_SAMPLE_RATE=16000
MIC_FRAME_SIZE=512
MIC_CHANNELS=1
MIC_DEVICE_INDEX=1
SPEAKER_DEVICE_INDEX=

# ── Wake Word ───────────────────────────────────────────────────────────────
WAKE_WORD=hey jarvis
# Optional override: openWakeWord model ID or a local .onnx/.tflite file path.
# Leave blank to derive from WAKE_WORD, e.g. "hey jarvis" -> "hey_jarvis".
WAKE_WORD_MODEL=
WAKE_WORD_THRESHOLD=0.5

# ── Session ─────────────────────────────────────────────────────────────────
SESSION_TIMEOUT_SEC=15

# ── Storage ─────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=./data/sqlite/navigator.db
CSV_DATA_DIR=./data/csv

# ── TTS Voices ──────────────────────────────────────────────────────────────
EDGE_TTS_VOICE_AR=ar-EG-SalmaNeural
EDGE_TTS_VOICE_EN=en-US-JennyNeural
DEFAULT_LANGUAGE=en

# ── Groq LLM ────────────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=8.0
GROQ_MAX_RETRIES=3
GROQ_RETRY_BACKOFF=1.0

# ── Router ──────────────────────────────────────────────────────────────────
ROUTER_CONFIDENCE_THRESHOLD=0.75

# ── Action Bridge ───────────────────────────────────────────────────────────
ACTION_BRIDGE_HOST=localhost
ACTION_BRIDGE_PORT=9090

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
