# Deepgram - English STT specialist (Nova-3)
DEEPGRAM_API_KEY=your_deepgram_key_here
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en

# ElevenLabs - Arabic STT specialist (Scribe v2 Realtime)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_MODEL=scribe_v2
ELEVENLABS_KEYTERMS_MAX=100
ELEVENLABS_PARTIAL_DEBUG=false

# Dual STT arbitration
STT_RACE_WINDOW_MS=600
STT_ARABIC_HOLD_MAX_MS=2000
STT_CONFIDENCE_MARGIN=0.10

# Groq - router and response generator
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SEC=8.0

# TTS - edge-tts voices
EDGE_TTS_VOICE_EN=en-US-JennyNeural
EDGE_TTS_VOICE_AR=ar-EG-SalmaNeural
EDGE_TTS_RATE=-10%

# Audio hardware
MIC_SAMPLE_RATE=16000
MIC_CHANNELS=1
MIC_FRAME_MS=30
MIC_DEVICE_INDEX=-1

# Wake word
WAKE_WORD=hey_navigator
WAKE_WORD_THRESHOLD=0.5
WAKE_COOLDOWN_SEC=2.0

# VAD
VAD_THRESHOLD=0.5
VAD_SILENCE_MS=800

# Session
SESSION_TIMEOUT_SEC=15.0
MAX_SESSION_TURNS=10

# Language detection
DEFAULT_LANGUAGE=en
LANG_CONFIDENCE_THRESHOLD=0.80

# Storage
SQLITE_DB_PATH=data/navigator.db
CSV_ENGLISH_DIR=data/csv_english
CSV_ARABIC_DIR=data/csv_arabic

# Logging
LOG_LEVEL=INFO
