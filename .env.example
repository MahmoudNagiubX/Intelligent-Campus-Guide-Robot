# ino example environment
# Copy this file to .env, then fill in your API keys.

# Required for English mode
DEEPGRAM_API_KEY=your_deepgram_key_here
GROQ_API_KEY=your_groq_key_here

# Deepgram - English STT
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en
DEEPGRAM_KEYTERM_PROMPTING_ENABLED=true
DEEPGRAM_ENDPOINTING_MS=500
DEEPGRAM_UTTERANCE_END_MS=1500

# English-only mode
# Keep true if you do not have ElevenLabs Arabic STT configured.
ENGLISH_ONLY_MODE=true

# ElevenLabs - Arabic STT, optional unless ENGLISH_ONLY_MODE=false
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=scribe_v2
ELEVENLABS_KEYTERMS_MAX=100
ELEVENLABS_PARTIAL_DEBUG=false

# Dual STT arbitration
STT_RACE_WINDOW_MS=600
STT_ARABIC_HOLD_MAX_MS=2000
STT_CONFIDENCE_MARGIN=0.10

# Groq - router and response generator
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SEC=8.0
GROQ_MAX_RETRIES=3
GROQ_RETRY_BACKOFF=1.0

# TTS - edge-tts voices
EDGE_TTS_VOICE_EN=en-US-ChristopherNeural
EDGE_TTS_VOICE_AR=ar-EG-SalmaNeural
EDGE_TTS_RATE=-10%
EDGE_TTS_RATE_AR=-3%
TTS_FALLBACK_PHRASE=Sorry, I had a small audio issue. Please ask me again.

# Optional ElevenLabs Arabic TTS
ELEVENLABS_TTS_ARABIC_ENABLED=false
ELEVENLABS_TTS_VOICE_AR=

# Audio hardware
MIC_SAMPLE_RATE=16000
MIC_CHANNELS=1
MIC_FRAME_MS=30
MIC_DEVICE_INDEX=-1
SPEAKER_DEVICE_INDEX=
PLAYBACK_ECHO_SUPPRESS_MS=1200.0

# Wake word
# ino uses the trained local openWakeWord model included in models/hey_ino.onnx.
WAKE_WORD=hey ino
WAKE_WORD_MODEL=models/hey_ino.onnx
WAKE_WORD_THRESHOLD=0.5
WAKE_COOLDOWN_SEC=2.0

# VAD
VAD_THRESHOLD=0.5
VAD_SILENCE_MS=900

# Session
SESSION_TIMEOUT_SEC=180
SESSION_TIMEOUT_SPEAKING_PAUSED=true
MAX_SESSION_TURNS=10

# Status publisher — robot screen / dashboard integration
STATUS_JSON_PATH=data/runtime_status.json
STATUS_WS_ENABLED=true
STATUS_WS_HOST=127.0.0.1
STATUS_WS_PORT=8765

# Wake acknowledgment — spoken after wake word is detected
WAKE_ACK_ENABLED=true
WAKE_ACK_TEXT_EN=Hello, I'm listening.
WAKE_ACK_LANGUAGE=en

# MQTT state publisher (wait / listen / speak)
# Set MQTT_ENABLED=true and fill in broker credentials in your .env (not here).
MQTT_ENABLED=false
MQTT_BROKER=
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=inno/ai
MQTT_TLS_ENABLED=true
MQTT_QOS=1
MQTT_RETAIN=true

# Language detection
DEFAULT_LANGUAGE=en
LANG_CONFIDENCE_THRESHOLD=0.80

# Storage
SQLITE_DB_PATH=data/sqlite/navigator.db
CSV_ENGLISH_DIR=data/csv_english
CSV_ARABIC_DIR=data/csv_arabic
CSV_DATA_DIR=data/csv_english
ECU_KNOWLEDGE_PATH=data/ecu_knowledge.json

# Router/action bridge
ROUTER_CONFIDENCE_THRESHOLD=0.75
ACTION_BRIDGE_HOST=localhost
ACTION_BRIDGE_PORT=9090

# Logging
LOG_LEVEL=INFO
